{
    "productName": "MusicGlass",
    "version": "1.0.0",
    "identifier": "com.musicglass.app",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../build",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "macOSPrivateApi": true,
        "windows": [
            {
                "label": "main",
                "title": "MusicGlass",
                "width": 1200,
                "height": 800,
                "resizable": true,
                "decorations": true,
                "transparent": true,
                "titleBarStyle": "Overlay"
            }
        ],
        "security": {
            "csp": "default-src 'self' tauri: localhost:; img-src 'self' asset: https: blob: data:; media-src 'self' asset: https: blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' asset:; connect-src 'self' asset: https: blob: data:;"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}